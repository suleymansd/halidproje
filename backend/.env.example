NODE_ENV=development
PORT=3000
API_PREFIX=api

DATABASE_URL=postgresql://isuchat:change_me@postgres:5432/isuchat

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=isuchat
POSTGRES_USER=isuchat
POSTGRES_PASSWORD=change_me

JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
INSTANCE_ID=isuchat-backend-1

CORS_ORIGIN=http://localhost:3001
LOG_LEVEL=info
RUN_MIGRATIONS=true

STORAGE_ENDPOINT=http://minio:9000
STORAGE_BUCKET=isuchat
STORAGE_ACCESS_KEY=change_me_access_key
STORAGE_SECRET_KEY=change_me_secret_key
